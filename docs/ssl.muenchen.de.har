const tryFn = (fn, fallback = null) => {\n  try {\n    return fn();\n  } catch (error) {\n    console.log(error.stack);\n    return fallback;\n  }\n}\n\n//DOMContentLoaded event handler\nfunction domReady() {\n  //initiate accordions\n  let accordions = document.getElementsByClassName(\"accordion\");\n  if(accordions.length > 0) {\n    initAccordion(accordions);\n  }\n}\n//DOMContentLoaded event listener\ndocument.addEventListener(\"DOMContentLoaded\", domReady);\n\n//window.onload = function (e) darf nicht vorkommen, stattdessen: *kg 14.6.12;\nspecialOnLoad = function (e) {\n  //initate platzhalter wenn auf der seite sind\n  let selectFields = document.querySelectorAll('select[data-adis-replace]');\n  if(selectFields.length > 0) {\n    setInvisibleHandler(selectFields);\n  }\n  //initiate ressponsive table headers\n  let respTables = document.getElementsByTagName(\"table\");\n  if(respTables.length > 0) {\n    for (var i = 0; i < respTables.length; i++) { \n      let id = respTables[i].getAttribute('id');\n      if (id != null) {\n        let matches = id.match(/resptable-([0-9]+)/);\n        if (matches != null) {\n          initResponsiveCellHeaders(id);\n        }\n      }\n    }\n  }\n  //initiate aria labels for tables\n  AddTableARIA();\n\n  //initiate linkbox-content and slider-content\n  let linkBoxFigures = document.querySelectorAll(\".linkbox :is(h2, h3, h4, h5, h6,) + figure\");\n  let sliderContentFigures = document.querySelectorAll(\".slider-content :is(h2, h3, h4, h5, h6,) + figure\");\n  if(linkBoxFigures.length > 0) {\n    wrapLinkBoxContent(linkBoxFigures);\n  }\n  if(sliderContentFigures.length > 0) {\n    wrapLinkBoxContent(sliderContentFigures);\n  }\n  //init resultlist if empty\n  let rlistColumns = document.querySelectorAll(\".rList_col\");\n  if (rlistColumns.length > 0){\n    for (index = 0; index < rlistColumns.length; ++index) {\n      rlistColumns[index].innerHTML = rlistColumns[index].innerHTML.replace(/^[\\s]+|^(\\&nbsp;)+|[\\s]+$|(\\&