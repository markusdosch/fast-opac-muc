            "size": 3831,
            "mimeType": "text/html",
            "compression": 684,
            "text": "<!DOCTYPE html>\r\n<html lang=\"de\">\r\n<head>\r\n<title text=\"Fehlerseite\">Fehlerseite</title>\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\r\n<meta charset=\"utf-8\" />\r\n<meta name=\"keywords\" content=\"OPAC, Bibliothekssoftware\" />\r\n<meta name=\"description\" content=\"Hinweis zum Bibliothekskatalog\" />\r\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,shrink-to-fit=no\" />\r\n<meta http-equiv=\"expires\" content=\"0\" />\r\n<meta http-equiv=\"cache-control\" content=\"no-cache\" />\r\n<meta http-equiv=\"pragma\" content=\"no-cache\" />\r\n<meta name=\"robots\" content=\"noindex,nofollow\" />\r\n<link rel=\"stylesheet\" href=\"/oidcp/css/openid.css\" type=\"text/css\"></link>\r\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/oidcp/images/favicon.ico\"></link>\r\n</head>\r\n<body class=\"opac01\">\r\n\t<div class=\"aDISMaske\">\r\n\t\t<div id=\"wrapper\">\r\n\t\t\t<div id=\"wrapper_inside\">\r\n\t\t\t\t<header id=\"header\">\r\n\t\t\t\t\t<div id=\"mhead\" class=\"block\">\r\n\t\t\t\t\t\t<div id=\"mhead-inside\">\r\n                        \r\n                           <div id=\"logo\" role=\"banner\">\r\n                                <a href=\"/aDISWeb/app\"><img src=\"/aDISWeb_stbm/images/logo.png\" alt=\"Logo\" /></a>\r\n                            </div>\r\n                            \r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</header>  \r\n\t\t\t\t<div id=\"container\">\r\n\t\t\t\t\t<div id=\"container-inside\">\r\n\t\t\t\t\t\t<div id=\"main\" role=\"main\">\r\n\t\t\t\t\t\t\t<div class=\"inside\">\r\n\t\t\t\t\t\t\t\t<div class=\"grid-wrapper\">\r\n\t\t\t\t\t\t\t\t\t<div class=\"grid-row\">\r\n\t\t\t\t\t\t\t\t\t\t<div class=\"grid-col col-12\">\r\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"grid-inside\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t<!--  START TEXT -->\r\n\t\t\t\t\t\t\t\t\t\t\t\t<h1>Ein Fehler ist aufgetreten</h1>\r\n                                                <div class=\"hinweis info\"><p><b>Liebe Nutzer*innen der MÃ¼nchner Stadtbibliothek</b>,</p><p> wenn Sie diese Seite sehen, gibt es ein technisches Problem mit dem Online-Katalog. Bitte <b>lÃ¶schen</b> Sie <b>Cache und Cookies</b> Ihres Browsers.</p><p>Achten Sie bitte auÃerdem darauf, den Katalog nicht von einem Lesezeichen oder dem Startbildschirm Ihres Handys aufzurufen, sondern starten Sie immer in einem neuen Browser-Tab.</p><p>Nutzen Sie bei Problemen mÃ¶glichst Firefox als Browser.</p></div>\r\n                                                <a href=\"/\">ZurÃ¼ck zur Startseite</a>\r\n                                                <!--  STOP TEXT  -->\r\n\t\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n                <footer id=\"footer\">\r\n                  <div class=\"inside\">\r\n                    <div class=\"grid-wrapper\">\r\n                      <div class=\"grid-row\">\r\n                        <div class=\"grid-col col-12\">\r\n                          <nav id=\"legal\" class=\"mod_navigation block\" aria-label=\"Rechtliche Links\">\r\n                            <ul>\r\n                              <li><a href=\"https://www.muenchner-stadtbibliothek.de/datenschutz\">Datenschutz</a></li>\r\n                              <li><a href=\"https://www.muenchner-stadtbibliothek.de/impressum\">Impressum</a></li>\r\n                            </ul>\r\n                          </nav>\r\n                        </div>\r\n                       <div class=\"grid-col col-12\">\r\n                         <p id=\"credits\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"https://www.astec.de\" target=\"_blank\" rel=\"noopener\">Barrierefreie Bibliothekssoftware der aStec angewandte Systemtechnik</a>\r\n                         </p>\r\n                       </div>\r\n                     </div>\r\n                    </div>\r\n\t\t\t\t\t<div class=\"clear\"></div>\r\n                  </div>\r\n                </footer>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n     <script>\r\n        // Automatische Weiterleitung X Sekunden\r\n        setTimeout(function() {\r\n            window.location.href = \"/\";\r\n        }, 20000);\r\n    </script>\r\n</body>\r\n</html>\r\n"
