  --advanced_symbol_suche_leeren_hover: url(\"/aDISWeb_kopac86/img/icons/remove.svg\");\n\n  /* Note-Symbole */\n  --note_symbol: url(\"/aDISWeb_kopac86/img/icons/star-empty.svg\");\n  --note_symbol_aktiv: url(\"/aDISWeb_kopac86/img/icons/star-full.svg\");\n  --note_symbol_angehakt: url(\"/aDISWeb_kopac86/img/icons/star-full.svg\");\n\n  /* Button-Merken Symbol */\n  --merken_symbol: url(\"/aDISWeb_kopac86/img/icons/star-full.svg\");\n  --merken_symbol_hover: url(\"/aDISWeb_kopac86/img/icons/star-full.svg\");\n\n  /* Leaflet Symbole */\n  --leaflet_symbol_layers: url(\"/aDISWeb_kopac86/img/icons/layers.svg\");\n  --leaflet_symbol_standort: url(\"/aDISWeb_kopac86/img/icons/location.svg\");\n  --leaflet_symbol_vollbild: url(\"/aDISWeb_kopac86/img/icons/fullscreen.svg\");\n  --leaflet_symbol_marker_inside: url(\"/aDISWeb_kopac86/img/icons/location-light.svg\");\n  --leaflet_symbol_marker_inside_hover: url(\"/aDISWeb_kopac86/img/icons/location.svg\");\n\n  /* Link Symbole */\n  --link_symbol_audio: url(\"/aDISWeb_kopac86/img/icons/file_audio.svg\");\n  --link_symbol_email: url(\"/aDISWeb_kopac86/img/icons/email.svg\");\n  --link_symbol_excel: url(\"/aDISWeb_kopac86/img/icons/file-excel.svg\");\n  --link_symbol_exe: url(\"/aDISWeb_kopac86/img/icons/file-exe.svg\");\n  --link_symbol_info: url(\"/aDISWeb_kopac86/img/icons/info.svg\");\n  --link_symbol_internal: url(\"/aDISWeb_kopac86/img/icons/internal.svg\");\n  --link_symbol_newwindow: url(\"/aDISWeb_kopac86/img/icons/newwindow.svg\");\n  --link_symbol_openoffice_text: url(\"/aDISWeb_kopac86/img/icons/file-oo.svg\");\n  --link_symbol_pdf: url(\"/aDISWeb_kopac86/img/icons/file-pdf.svg\");\n  --link_symbol_portal: url(\"/aDISWeb_kopac86/img/icons/portal.svg\");\n  --link_symbol_publication: url(\"/aDISWeb_kopac86/img/icons/publication.svg\");\n  --link_symbol_ppt: url(\"/aDISWeb_kopac86/img/icons/file-ppt.svg\");\n  --link_symbol_rtf: url(\"/aDISWeb_kopac86/img/icons/file-rtf.svg\");\n  --link_symbol_top: url(\"/aDISWeb_kopac86/img/icons/top.svg\");\n  --link_symbol_txt: url(\"/aDISWeb_kopac86/img/icons/file-txt.svg\");\n  --link_symbol_video: url(\"/aDISWeb_kopac86/img/icons/file-video.svg\");\n  --link_symbol_word: url(\"/aDISWeb_kopac86/img/icons/file-word.svg\");\n  --link_symbol_zinfo: url(\"/aDISWeb_kopac86/img/icons/file_zinfo.svg\");\n  --link_symbol_zip: url(\"/aDISWeb_kopac86/img/icons/file-zip.svg\");\n\n}\n/* ENDE DEFINITIONEN --- */\n\n/* Logo wird sonst nicht angezeigt*/\n.sticky-wrapper-fixed #logo img {\n  min-width: 7em;\n}\n\n/* in mobiler Ansicht sonst zu groÃÆÃÂ¸*/\n#logo img.img-standard {\n  max-height: 59px;\n  max-width: 90%;\n}\n\n/*border on anmelden page*/\nlegend {\nborder: none;\n}\n\n/*break word in Mein Konto*/\n.html_div dl {\nword-break: break-word;\n}\n\n/*pass aendern input*/\nselect#LPASSN_1 {\nmax-width: 75%;\n}\n\nh2 {\nfont-size: 1.55rem;\n}\n\ninput, img, a, button,select {\nborder-radius: 1.5rem;\n}\n\n.rte-link-button {\n    padding: 2px;\n    border-radius: 1.5rem;\n}\n\ninput, select {\npadding-inline: 1rem;\n}\n#logo img,\n#logo a,\nh1 > a,\nh2 > a,\nh3 > a,\nh4 > a, \np a,\n.resultlist a, \n.resultlist img, \n.toolbar_filter,\n.toolbar_filter img, \n.toolbar_li input, \n.toolbar_li img {\nborder-radius: 0;\n\n}\n\n.rList_cover {\npadding: 0.1em;\nborder-radius: 1rem;\n}\n\n#mnav input,\n#mnav a:link,\n#mnav a:hover,\n#lnav input,\n#lnav a:link,\n#lnav a:hover {\npadding-inline: 1rem;\nborder-color: transparent;\nbox-shadow: 0 0 0 transparent!important;\n}\n\n#search .field-buttons-adv input.search-adv,\n#search .field-buttons input.imp-button {\nbackground-position-x: 0.625rem;\n}\n#search .field-buttons-adv input.search-adv {\nmargin-left: 0;\n}\n#search .grid-inside {\ngap: 0.5em;\n}\n\n#search button, #search input, #search select, #search .replacedSelect {\n  padding: 0.625rem 2.55rem 0.625rem .625rem !important;\n}\n\n@media (max-width: 991px) {\n#search .grid-inside {\n  width: 95%;\n  margin: auto;\n  padding: 0;\n}\n#search .grid-col:first-child {\n  padding-left: 0;\n}\n}\n@media (max-width: 991px) {\n#searchBtn-wrapper {\n  background-color: transparent!important;\n}\n}\n\n#mhead {\n  /* background-image: url(\"/aDISWeb_stbm/images/OPAC-Header_2_kk.png\"); */\n  background-size: 100%;\n  background-repeat: no-repeat;\n  background-position: center center;\n}\n\n#logo a, #logo a:link, #logo a:visited {\n  background: transparent;!important\n}\n\ninput[type=\"text\"], input[type=\"password\"], input.feld_ausweis {\n  padding-left: 1rem;\n}\n\n.payContainer img {\n  border-radius: 0!important;\n}\n\n.aDISMaske #main {\n\t border-radius: 1.5rem;\n}\n\n.cbtree_leaf_a:link,\n.cbtree_leaf_a:visited,\n.cbtree_leaf_a:hover,\n.cbtree_leaf_a:focus {\n  padding-left: 0.5rem!important;\n  padding-right: 0.5rem!important;\n}\n\n.rList_titel a {\n  padding-left: 0.5rem!important;\n  padding-right: 0.5rem!important;\n  border-radius: 1.5rem!important;\n}\n\n/* KORREKTUREN FEBRUAR 2026 --- */\n\n/* Vollanzeige */\n/* Coverbilder in der Vollanzeige */\n.show-full-basics img {\n    border-radius: 0 !important;\n}\n/* Links in der Vollanzeige */\n#results a {\n    /* border-radius: 0 !important; */\n    text-decoration: none;\n    /* text-decoration: underline dotted; */ /* alternative */\n    border: none;\n    outline: none;\n    box-shadow: none;\n    border-radius: 0; /* globaler Standard */\n}\n#results a:hover,\n#results a:focus {\n    text-decoration: underline solid;\n    border: none;\n    outline: none;\n    box-shadow: none;\n}\nimg.icon {\n    border-radius: 0em !important;\n}\n/* Buttons Bestellen, Speichern, Filtern */\n#options input.bestellen[type=\"submit\"],\n#options input.speichern[type=\"submit\"],\n#options input.suche-starten[type=\"submit\"],\n#options input.filter[type=\"submit\"] {\n    padding-left: 2em !important;\n}\n\n/* FAQ */\n.accordion a {\n    text-decoration: none;\n    border: none;\n    outline: none;\n    box-shadow: none;\n    /* background: transparent; */\n    /* color: inherit; */\n    border-radius: 0em !important;\n}\n.accordion a:hover,\n.accordion a:focus {\n    text-decoration: underline;\n    border: none;\n    outline: none;\n    box-shadow: none;\n}\n\n/* Konto */\n#konto-services a,\n#konto-services span {\n    border-radius: 1.5em !important;\n}\n\n/* Ergebnisliste */\n.rList_titel a {\n    padding-left: 0 !important;\n    padding-right: 0 !important;\n    border-radius: 0 !important;\n}\n.rList_button button {\n    background-position: 0.5em center !important;\n    padding-left: 2em !important;\n    padding-right: 0.5em !important;\n}\n/* folgendes greift nur, wenn border als decoration aktiv ist */\n#results .rList_www a {\n    border-radius: 1.5em !important;\n    background-position: 0.5em center !important;\n    padding-left: 2em !important;\n    padding-right: 0.5em !important;\n}\n.rList_cover {\n    background-color: transparent !important;\n}\n@media only screen and (max-width: 575px) {\n    .rList_cover img {\n        min-height: auto !important;\n    }\n}\n#options button.accordion-toggler {\n    padding-left: 1.5em !important;\n}\n#options input[type=\"submit\"] {\n    background-position: 0.5em center !important;\n}\n.rList_titel a:hover,\n.rList_titel a:focus,\n.rList_titel a:active {\n    box-shadow: none !important;\n    border-color: transparent !important;\n    background-color: transparent !important;\n    text-decoration: underline !important;\n}\n\n/* inspira_BIB */\n.cover-container {\n    padding: 15px;\n    background-color: #f1f1f1;\n    border-radius: 1.2em;\n}\n.carousel-item img.icon {\n    border-radius: 3px !important;\n    padding: 3px !important;\n}\n.carousel-item .item-image {\n    border-radius: 0em !important;\n    box-shadow: 5px 5px 0.22rem rgba(0,0,0,0.3) !important;\n}\n@media (max-width: 768px) {\n    .carousel-item img {\n        width: 100%;\n    }\n}\n\n/* Startseite, Monacensia, Medienlisten */\n.container-adiscontent:not(:has(.accordion)) img:hover {\n    border-radius: 1.4em; /* minimal kleiner */\n}\n/* Text-Link als Button */\n.container-adiscontent:not(:has(.accordion)) a:not(:has(img)) {\n    display: inline-block;\n    padding: 0.4em 1em;\n    border: 2px solid currentColor;\n    color: #d14800 !important;\n    border-radius: 1.5em;\n    text-decoration: none;\n    background-color: transparent;\n    outline: none !important;\n    box-shadow: none !important;\n    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;\n}\n.container-adiscontent:not(:has(.accordion)) a:not(:has(img)):hover {\n    background: #d14800 !important;\n    color: #fff !important;\n    border-color: #d14800 !important;\n    outline: none !important;\n    box-shadow: none !important;\n}\n\n/* Digitale Angebote */\n.dw-page a:has(img),\n.ebibo-grid a:has(img) {\n    display: inline-block;\n    border: 2px solid transparent; /* Border immer vorhanden */\n    border-radius: 1.5em;\n    overflow: hidden; /* verhindert Blitzer */\n    transition: border-color 0.2s ease;\n}\n.dw-page a img,\n.ebibo-grid a img {\n    display: block; /* verhindert Whitespace und Verschiebungen */\n    border: 2px solid transparent; /* immer vorhanden, verhindert Jumping */\n    border-radius: 1.5em;\n    transition: border-color 0.2s ease;\n}\n.dw-page a:hover img,\n.ebibo-grid a:hover img {\n    border-color: currentColor; /* nur Farbe Ã¤ndert sich */\n}\n.dw-page a:not(:has(img)),\n.ebibo-grid a:not(:has(img)) {\n    border: none; /* wichtig! */\n    text-decoration: none;\n}\n.dw-page a:not(:has(img)):hover,\n.ebibo-grid a:not(:has(img)):hover {\n    text-decoration: underline;\n}\n\n/* Druck-Button */\na.drucken-no {\n    text-decoration: none !important;\n    border-radius: 1.5em !important;\n}\n\n/* Footer */\n#footer a {\n    text-decoration: none !important;\n    border-radius: 1.5em !important;\n    border: none !important;\n    outline: none !important;\n    box-shadow: none !important;\n}\n#footer a:hover,\n#footer a:focus,\n#footer a:active {\n    text-decoration: underline !important;\n    border: none !important;\n    outline: none !important;\n    box-shadow: none !important;\n}\n#credits::after {\n    content: \"\";\n    display: block;\n    width: 12em;\n    aspect-ratio: 4 / 1;\n    background-image: url(\"https://www.muenchner-stadtbibliothek.de/typo3conf/ext/msb-theme/Resources/Public/Images/logo-lhm-schwarz.svg\");\n    background-size: contain;\n    background-repeat: no-repeat;\n    background-position: left center;\n    margin-top: 1em;\n    margin-left: 0.3em;\n}\n\n/* ENDE KORREKTUREN FEBRUAR 2026 --- */"
