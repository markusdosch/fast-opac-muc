.geoJSONData = null;\n\tthis.geodata = null;\n\tthis.map = null;\n\tthis.showevent = \"\";\n\tthis.centerpoint = null;\n\t\n\tthis.osm = {};\n\tthis.osm.url = null;\n\tthis.osm.attribution = null;\n\t\n\tthis.wms = {};\n\tthis.wms.url = null;\n\tthis.wms.options = null;\n\t\n\tthis.locateme = false;\n\n\tthis.markers = {};\n\tthis.markers.data = [];\n\tthis.markers.usedefault = true;\n\tthis.markers.showlabel = true;\n\tthis.markers.colors = [\"\", \"#fe4a49\", \"#2ab7ca\", \"#fed766\", \"#051e3e\", \"#251e3e\", \"#451e3e\", \"#651e3e\", \"#851e3e\", \"#4a4e4d\", \"#0e9aa7\", \"#3da4ab\", \"#f6cd61\", \"#fe8a7\", \"#ee4035\", \"#f37736\", \"#fdf498\", \"#7bc043\", \"#0392cf\", \"#ff6f69\", \"#ffcc5c\"];\n\tthis.helpers = {};\n\tthis.helpers.imgbuttonIn = mapLang.zoomInToMarker;\n\tthis.helpers.imgbuttonOut = mapLang.zoomOutfromMarker;\n\tthis.helpers.imgbuttonGoto = mapLang.goToDetails;\n\n};\n\nMapPanel.prototype = {\n\t\tconstuctor: MapPanel\n};\nMapPanel.prototype.init = function(mapid, geodata){\n\tif(!mapid) return false;\n\telse this.mapid = mapid;\n\n\tif(!this.geodata  && !this.centerpoint)\n\t\treturn false;\n\n\tif(!this.centerpoint)// take the frist from geodata\n\t\tthis.centerpoint = this.geodata[0].geometry.coordinates;\t\t\n\t\t\n\taDISStaticMapData.mappanel = this;\n}\n\nMapPanel.prototype.show = function() { \n\tif(this.map)\n\t\treturn true;\n\n\tvar mapDiv = document.getElementById(this.mapid);\n\tif(!mapDiv)\n\t\treturn false;\n\n\tmapDiv.setAttribute(\"role\", \"region\");\n\tmapDiv.setAttribute(\"aria-label\", mapLang.mapTitle);\n\tmapDiv.classList.add(\"adis-nosubmit\");\n\n\t// setze Abmessung der Karte\n\tif(this.mapstyle != \"\") \n\t\tmapDiv.setAttribute(\"style\", this.mapstyle);\n\n\t//karte initialisieren\n\tthis.map = new L.Map(this.mapid, {zoomControl: false, scrollWheelZoom: false, gestureHandling: true}); \n\t\n\tvar baseTileLayer = null;\n\tif(this.wms && this.wms.url){\n\t\t//WMS Layer\n\t\tthis.wms.options.maxzoom = this.maxzoom;\n\t\tthis.wms.options.minzoom = this.minzoom;\n\t\tbaseTileLayer =  L.tileLayer.wms(this.wms.url, this.wms.options);\n\t}\n\telse if(this.osm && this.osm.url){\n\t\t//OSM Layer\n\t\tbaseTileLayer = new L.TileLayer(this.osm.url, {maxZoom: this.maxzoom, attribution: this.osm.attribution});\n\t}\n\tthis.map.addLayer(baseTileLayer);\n\taDISStaticMap = this.map;\n\n\t// setzte Overlay-Anzeige\n\tvar layerControl = L.control.layers(null, null);\n\n\t// setze geoJSONData z.B. Bezirke auf die Karte\n\tif(this.geoJSONData != null){\n\t\tvar geoJLayer = L.geoJSON(this.geoJSONData,{\n\t\t\tstyle: function (feature) {return {color: feature.properties.Farbe};},\n\t\t\tonEachFeature:function(feature, layer){\n\t\t\t\tlayer.on({\n\t\t\t\t\tmouseover: function(){this.setStyle({color:'red'})},\n\t\t\t\t\tmouseout:  function(){this.setStyle({color:'#76b4bd'})},\n\t\t\t\t});\n\t\t\t}\n\t\t}).bindPopup(function (layer) {\n\t\t\treturn layer.feature.properties.Gemeinde_name;\n\t\t});\n\t\tgeoJLayer.addTo(this.map);\n\t\tlayerControl.addOverlay(geoJLayer, \"Bezirke\");\n\t}\n\n\t// zoom control options\n\tvar zoom = L.control.zoom(mapLang);   // Creating zoom control\n\tzoom.addTo(this.map);   // Adding zoom control to the map\n\n\t// Position des Nutzers automatisch bestimmen\n\tif(this.locateme)\n\t\tthis.locate();\n\telse\n\t\tthis.map.setView(this.centerpoint, this.zoom);\n\n\t// Marker setzen\n\tvar group = new L.FeatureGroup();\n\tfor(var i = 0; i < this.geodata.length; i++){\n\t\tvar f = this.geodata[i];\n\t\tif(f.geometry.coordinates){\n\t\t\tvar marker = null;\n\t\t\tif(this.markers.usedefault)\n\t\t\t\tmarker = L.marker(f.geometry.coordinates,{title:f.properties.name, medium:f.properties.medium});\n\t\t\telse{\n\t\t\t\tvar markerColorIndex = f.properties.markerColorInd?f.properties.markerColorInd:i;\n\t\t\t\tmarker = new aDISMarker(f.geometry.coordinates,\n\t\t\t\t\t{icon: this.createCustomIcon(markerColorIndex, f.properties.name, i), title:f.properties.name, customId: \"adisMarker-\" + i});\n\t\t\t}\n\t\t\t//Marker popup text\n\t\t\tvar popupText = \"<div class = 'adis-popup-header'><h4>\" + f.properties.name + \"</h4></div>\";\n\t\t\tif(f.properties.adress) {\n\t\t\t\tpopupText += \"<div class = 'adis-popup-adress'>\" + f.properties.adress + \"</div>\";\n\t\t\t\tvar splitAdress = f.properties.adress.split(\"<br>\");\n\t\t\t\tif(splitAdress[1] && splitAdress[2]) {\n\t\t\t\t\tvar routeUri = encodeURI(\"https://maps.google.de/maps/?daddr=\" + splitAdress[1] + \"+\" + splitAdress[2]);\n\t\t\t\t\tpopupText += \"<div class = 'adis-popup-route'><a href='\" + routeUri + \"' target='_blank' rel='nofollow noopener' aria-label='Routenplaner (neues Browser-Fenster)'>Routenplaner</a>\";\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(f.properties.info)\n\t\t\t\tpopupText += \"<div class = 'adis-popup-info'>\" + f.properties.info + \"</div>\";\n\t\t\t//buttons\n\t\t\tpopupText += \"<div class = 'adis-popup-functions'>\";\n\t\t\tpopupText += \"<button type='button' class='adis-map-button adis-map-ico-zoom-in' data-action='in' onclick='aDISStaticMapData.mappanel.zoomIntoPoint(this, [\" + f.geometry.coordinates + \"] );  return false;'>\"+this.helpers.imgbuttonIn + \"</button><div class='klar'></div>\";\n\t\t\t\n\t\t\tif(f.properties.info_target_id && f.properties.info_target_id !=\"\")\n\t\t\t\tpopupText += \"<button type='button' class='adis-map-button adis-map-ico-details' onclick='aDISStaticMapData.mappanel.gotoElementOnPage(this, \\\"\" + f.properties.info_target_id + \"\\\"); return false;'>\"+this.helpers.imgbuttonGoto+\"</button><div class='klar'></div>\";\n\t\t\tpopupText += \"</div>\";\n\t\t\t\n\t\t\tmarker\n\t\t\t\t.bindPopup(popupText, {closeOnEscapeKey: true})\n\t\t\t\t.on('popupopen', function (e) {\n\t\t\t\t\tvar marker = e.popup._source;\n\t\t\t\t\tmarker.getElement().setAttribute(\"aria-expanded\", \"true\");\n\t\t\t\t\te.popup._map._panes.popupPane.setAttribute(\"aria-labeledby\", marker.options.customId);\n\t\t\t\t\te.popup._map._panes.popupPane.querySelector(\".leaflet-popup-close-button\").setAttribute(\"aria-label\", mapLang.closePopup);\n\t\t\t\t\te.popup._map._panes.popupPane.querySelector(\".adis-map-button.adis-map-ico-zoom-in\").focus();\n\t\t\t\t})\n\t\t\t\t.on('popupclose', function (e) {\n\t\t\t\t\tvar marker = e.popup._source;\n\t\t\t\t\tmarker.getElement().setAttribute(\"aria-expanded\", \"false\");\n\t\t\t\t\tmarker.getElement().focus();\n\t\t\t\t\te.popup._map._panes.popupPane.removeAttribute(\"aria-labeledby\");\n\t\t\t\t});\n\n\t\t\tgroup.addLayer(marker);\n\t\t\tthis.markers.data.push(marker);\n\t\t}\n\t}\n\tthis.map.addLayer(group); \n\n\t//Customize Marker Div elements for Accessebility\n\tvar adisMarkers = document.querySelectorAll(\"#mappanel div.leaflet-marker-icon.my-custom-pin\");\n\n\tif(adisMarkers.length > 0) {\n\t\tfor(var i = 0; i < adisMarkers.length; i++){\n\t\t\tvar marker = adisMarkers[i];\n\t\t\tvar gd = this.geodata[i];\n\t\t\tmarker.setAttribute(\"id\", this.markers.data[i].options.customId);\n\t\t\tmarker.setAttribute(\"aria-label\", gd.properties.name);\n\t\t\tmarker.setAttribute(\"aria-expanded\", \"false\");\n\t\t\tmarker.setAttribute(\"aria-controls\", \"adis-popup-pane\");\n\t\t}\n\t}\n\n\t//Customize Popup for Accessebility\n\tvar adisPopup = document.querySelector(\"#mappanel div.leaflet-pane.leaflet-popup-pane\");\n\n\tif(adisPopup) {\n\t\tadisPopup.setAttribute(\"id\", \"adis-popup-pane\");\n\t\tadisPopup.setAttribute(\"role\", \"dialog\");\n\t\tadisPopup.setAttribute(\"aria-modal\", \"true\");\n\t}\n\n\treturn true;\n}\n\nMapPanel.prototype.zoomIntoPoint = function(el, coordinates) {\n\tif(el.getAttribute(\"data-action\") == \"in\"){\n\t\tif(this.map.getZoom() != this.maxzoom)\n\t\t\taDISStaticMapData.mappanel.zoomlevel = this.map.getZoom();\n\t\tthis.map.setView(coordinates, this.maxzoom);\n\t\tel.innerHTML = this.helpers.imgbuttonOut;\n\t\tel.setAttribute(\"class\", \"adis-map-button adis-map-ico-zoom-out\");\n\t\tel.setAttribute(\"data-action\", \"out\");\n\t}\n\telse{\n\t\tel.innerHTML = this.helpers.imgbuttonIn;\n\t\tel.setAttribute(\"class\", \"adis-map-button adis-map-ico-zoom-in\");\n\t\tthis.map.setView(coordinates, aDISStaticMapData.mappanel.zoomlevel);\n\t\tel.setAttribute(\"data-action\", \"in\");\n\t}\n}\n\nMapPanel.prototype.createCustomIcon = function(index, label, id) {\n\tvar customColor = \"#ffffff\";\n\tif(this.markers.colors && this.markers.colors.length >= 1){\n\t\tif(index >= this.markers.colors.length)\n\t\t\tindex = 0;\n\t\tcustomColor = this.markers.colors[index];\n\t}\n\n\t// Template literals are enclosed by the back-tick (` `) (grave accent)\n\t// instead of double or single quotes\n\tvar markerHtmlStyles = \"background-color: \"+ customColor + \"; width: 2rem; height: 2rem; display: block; left: -1.5rem; top: -1.5rem; position: relative; border-radius: 3rem 3rem 0; transform: rotate(45deg); border: 1px solid #FFFFFF\";\n\n\tvar textStyles = \"display: block;left: -0.7rem; top: -3rem; position: relative; color: white;font-weight:bold;\";\n\tvar name = (this.markers.showlabel && label!=null)? label[0]:'B';\n\tvar myIcon = L.divIcon({\n\t\tclassName: \"my-custom-pin adis-nosubmit\",\n\t\ticonAnchor: [0, 24],\n\t\tlabelAnchor: [-6, 0],\n\t\tpopupAnchor: [0, -36],\n\t\thtml: '<span style=\"' + markerHtmlStyles + \n\t\t\t'\"></span><span style=\"' + textStyles + '\">' + name + '</span>'\n\t});\n\treturn myIcon;\n\n}\n\nMapPanel.prototype.showMarker = function(el, id) { \n\tif(!this.markers.data) return false;\n\tfor (var i in this.markers.data){\n        var markerID = this.markers.data[i].options.title;\n        if (markerID == id){\n            this.markers.data[i].openPopup();\n            this.map.setView(this.markers.data[i].getLatLng()); //, this.maxzoom\n            document.getElementById(this.mapid).scrollIntoView();\n        }\n    }\n}\n\nMapPanel.prototype.gotoElementOnPage = function(el, id) { \n\t var el = document.getElementById(id);\n\t if(el)\n\t\tel.scrollIntoView();\n}\n\n\nMapPanel.prototype.locate = function() {\n\tif(!this.map) return false;\n\tthis.map.locate({setView: true, maxZoom:this.zoom, watch: false}) \n\t.on('locationfound', this.lochandler.bind(this))\n\t.on('locationerror', function(e){\n\t\treturn false;\n\t});\n}\n\nMapPanel.prototype.lochandler = function(e) {\n\tif (e.type == \"locationfound\" ){\n\t\tvar marker = L.marker([e.latitude, e.longitude],{title:\"marker_me\"}).bindPopup('Mein Standort').openPopup();\n\t\tthis.markers.data.push(marker);\n\t\tthis.map.addLayer(marker);\n\t}\n\treturn true;\n}\n\nMapPanel.prototype.handler = function(e) {\n\tif (e.type != this.showevent ) return false;\n\n\tthis.show();\t\n\treturn true;\n}\n"
          },
